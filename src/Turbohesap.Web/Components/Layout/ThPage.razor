@namespace Turbohesap.Web.Components.Layout
@inject Turbohesap.Web.Services.PageTabService Tabs
@inject NavigationManager Nav

@* Sayfa sarmalayıcı (DESIGN.md §Yerleşim). Normal sayfalarda kenar boşluğu; tam-ekran (harita
   vb.) sayfalarda Flush. Render edilince sayfayı PageTabs'a kaydeder; alt içeriğe sekme tutamacı
   (PageTabHandle) cascading olarak verilir; sayfalar kirli durumu bunun üzerinden bildirir. *@
<CascadingValue Value="_handle" IsFixed="true">
    <div class="@(Flush ? "th-page th-page--flush" : "th-page")" style="@(Footer is not null && FooterFixed ? "padding-bottom: calc(var(--th-content-padding) + var(--th-footer-height));" : null)">
        @if (!string.IsNullOrEmpty(Title) || Actions is not null)
        {
            <div class="th-page-header">
                <div>
                    @if (!string.IsNullOrEmpty(Title))
                    {
                        <h1 class="th-page-title">@Title</h1>
                    }
                    @if (!string.IsNullOrEmpty(Subtitle))
                    {
                        <div class="th-page-subtitle">@Subtitle</div>
                    }
                </div>
                @if (Actions is not null)
                {
                    <div class="th-page-actions">@Actions</div>
                }
            </div>
        }
        @ChildContent
    </div>

    @if (Footer is not null)
    {
        <div class="@(FooterFixed ? "th-footer th-footer--fixed" : "th-footer")">@Footer</div>
    }
</CascadingValue>

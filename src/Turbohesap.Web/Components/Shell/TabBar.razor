@namespace Turbohesap.Web.Components.Shell
@implements IDisposable
@inject Turbohesap.Web.Services.TabService Tabs
@inject NavigationManager Nav

@if (Tabs.Tabs.Count > 0)
{
    <div class="th-tabbar">
        @foreach (var tab in Tabs.Tabs)
        {
            <div class="@(IsActive(tab) ? "th-tab th-tab--active" : "th-tab")" @key="tab.Href" @onclick="() => Activate(tab)">
                <i class="@($"th-tab__icon {tab.Icon}")"></i>
                <span class="th-tab__label">@tab.Title</span>
                @if (tab.Closable)
                {
                    <span class="th-tab__close" @onclick:stopPropagation="true" @onclick="() => Close(tab)">
                        <i class="fa-solid fa-xmark"></i>
                    </span>
                }
            </div>
        }
    </div>
}

@code {
    protected override void OnInitialized()
    {
        Tabs.OnChange += Changed;
        Nav.LocationChanged += OnLocationChanged;
        SyncActive();
    }

    private bool IsActive(TabItem tab) => string.Equals(Tabs.ActiveHref, tab.Href, StringComparison.OrdinalIgnoreCase);

    private void Activate(TabItem tab)
    {
        Tabs.SetActive(tab.Href);
        Nav.NavigateTo(tab.Href);
    }

    private void Close(TabItem tab)
    {
        var next = Tabs.Close(tab.Href);
        if (next is not null)
        {
            Nav.NavigateTo(next);
        }
    }

    private void SyncActive()
    {
        var path = new Uri(Nav.Uri).AbsolutePath;
        if (Tabs.Tabs.Any(t => string.Equals(t.Href, path, StringComparison.OrdinalIgnoreCase)))
        {
            Tabs.SetActive(path);
        }
    }

    private void Changed() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        SyncActive();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Tabs.OnChange -= Changed;
        Nav.LocationChanged -= OnLocationChanged;
    }
}

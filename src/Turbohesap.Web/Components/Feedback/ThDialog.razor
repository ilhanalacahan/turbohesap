@namespace Turbohesap.Web.Components.Feedback
@inherits Turbohesap.Web.Components.Base.TurboComponentBase

@if (Visible)
{
    <div class="th-overlay" @onclick="OnOverlayClick">
        <div class="@RootClass" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
            <div class="th-panel-header">
                <div>
                    <div class="th-panel-title">@Title</div>
                    @if (!string.IsNullOrEmpty(Subtitle))
                    {
                        <div class="th-panel-subtitle">@Subtitle</div>
                    }
                </div>
                <span class="th-dialog__close" @onclick="CloseAsync"><i class="fa-solid fa-xmark"></i></span>
            </div>
            <div class="th-dialog__body">@ChildContent</div>
            @if (Footer is not null)
            {
                <div class="th-dialog__footer">@Footer</div>
            }
        </div>
    </div>
}

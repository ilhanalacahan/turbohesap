@page "/login"
@layout Turbohesap.Web.Components.Layout.AuthLayout
@inject Turbohesap.Web.Services.AuthClientService Auth
@inject Turbohesap.Web.Services.ToastService Toasts
@inject NavigationManager Nav

<div class="th-login">
    <aside class="th-login__brand">
        <div class="th-login__brand-top">
            <span class="th-login__logo"><i class="fa-solid fa-calculator"></i></span>
            <span class="th-login__brand-name">Turbohesap</span>
        </div>

        <div class="th-login__brand-body">
            <h1 class="th-login__headline">İşletmenizin finansını tek yerden yönetin.</h1>
            <p class="th-login__subhead">Cari, fatura, stok ve raporlama — hızlı, güvenli ve modern ön muhasebe deneyimi.</p>

            <div class="th-login__slides">
                <div class="th-login__slide" @key="_slide">
                    <span class="th-login__slide-icon"><i class="@_slides[_slide].Icon"></i></span>
                    <div>
                        <div class="th-login__slide-title">@_slides[_slide].Title</div>
                        <div class="th-login__slide-text">@_slides[_slide].Text</div>
                    </div>
                </div>
                <div class="th-login__dots">
                    @for (var i = 0; i < _slides.Length; i++)
                    {
                        var index = i;
                        <button type="button" class="@(index == _slide ? "th-login__dot th-login__dot--active" : "th-login__dot")"
                                @onclick="@(() => ShowSlide(index))" aria-label="Slayt"></button>
                    }
                </div>
            </div>
        </div>

        <div class="text-sm" style="position:relative;z-index:1;color:rgba(255,255,255,0.7)">
            © @DateTime.Now.Year Turbohesap · Tüm hakları saklıdır.
        </div>
    </aside>

    <main class="th-login__form-side">
        <div class="th-login__form">
            <div class="th-login__form-head">
                <span class="th-login__form-logo"><i class="fa-solid fa-calculator"></i></span>
                <h2 class="th-login__title">Tekrar hoş geldiniz</h2>
                <p class="th-login__hint">Devam etmek için hesabınıza giriş yapın.</p>
            </div>

            <EditForm Model="_model" OnValidSubmit="SubmitAsync">
                <FluentValidationValidator />
                <div style="display:flex;flex-direction:column;gap:1rem">
                    <ThField TValue="string" Label="E-posta" Required For="() => _model.Email">
                        <InputText class="th-input" @bind-Value="_model.Email" placeholder="ornek@firma.com" autocomplete="username" />
                    </ThField>
                    <ThField TValue="string" Label="Parola" Required For="() => _model.Password">
                        <InputText type="password" class="th-input" @bind-Value="_model.Password" placeholder="••••••••" autocomplete="current-password" />
                    </ThField>
                    <ThButton Type="submit" Variant="ButtonVariant.Primary" Block Loading="_busy" Icon="fa-solid fa-right-to-bracket">
                        Giriş Yap
                    </ThButton>
                </div>
            </EditForm>

            <div class="th-login__demo">
                Demo: <strong>admin@turbohesap.local</strong> / <strong>Admin123!</strong>
            </div>
        </div>
    </main>
</div>

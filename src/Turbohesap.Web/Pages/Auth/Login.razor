@page "/login"
@layout Turbohesap.Web.Components.Layout.AuthLayout
@inject Turbohesap.Web.Services.AuthClientService Auth
@inject Turbohesap.Web.Services.ToastService Toasts
@inject NavigationManager Nav

<div class="th-card" style="width:100%;max-width:24rem">
    <div class="th-card__body" style="padding:1.75rem">
        <div style="text-align:center;margin-bottom:1.25rem">
            <span class="th-sidebar__appicon" style="margin:0 auto 0.75rem;width:3rem;height:3rem;font-size:1.25rem">
                <i class="fa-solid fa-calculator"></i>
            </span>
            <h1 class="th-page-title">Turbohesap</h1>
            <p style="color:var(--th-text-muted);font-size:0.875rem;margin-top:0.25rem">Hesabınıza giriş yapın</p>
        </div>

        <EditForm Model="_model" OnValidSubmit="SubmitAsync">
            <FluentValidationValidator />
            <div style="display:flex;flex-direction:column;gap:1rem">
                <ThField TValue="string" Label="E-posta" Required For="() => _model.Email">
                    <InputText class="th-input" @bind-Value="_model.Email" placeholder="ornek@firma.com" autocomplete="username" />
                </ThField>
                <ThField TValue="string" Label="Parola" Required For="() => _model.Password">
                    <InputText type="password" class="th-input" @bind-Value="_model.Password" placeholder="••••••••" autocomplete="current-password" />
                </ThField>
                <ThButton Type="submit" Variant="ButtonVariant.Primary" Block Loading="_busy" Icon="fa-solid fa-right-to-bracket">
                    Giriş Yap
                </ThButton>
            </div>
        </EditForm>

        <p style="margin-top:1rem;font-size:0.75rem;color:var(--th-text-subtle);text-align:center">
            Demo: admin@turbohesap.local / Admin123!
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private readonly LoginRequest _model = new();
    private bool _busy;

    private async Task SubmitAsync()
    {
        _busy = true;
        try
        {
            await Auth.LoginAsync(_model);
            var target = string.IsNullOrEmpty(ReturnUrl) ? "/dashboard" : Uri.UnescapeDataString(ReturnUrl);
            Nav.NavigateTo(target, forceLoad: false);
        }
        catch (ApiException ex)
        {
            Toasts.Error(ex.Message, "Giriş başarısız");
        }
        finally
        {
            _busy = false;
        }
    }
}

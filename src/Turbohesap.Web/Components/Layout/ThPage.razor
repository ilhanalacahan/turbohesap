@namespace Turbohesap.Web.Components.Layout

@* Sayfa sarmalayıcı (req 29). Normal sayfalarda kenar boşluğu; harita gibi tam-ekran
   sayfalarda Flush ile boşluk kaldırılır. Üstte başlık+aksiyonlar, altta opsiyonel footer. *@
<div class="@(Flush ? "th-page th-page--flush" : "th-page")">
    @if (!string.IsNullOrEmpty(Title) || Actions is not null)
    {
        <div class="th-page-header">
            <div>
                @if (!string.IsNullOrEmpty(Title))
                {
                    <h1 class="th-page-title">@Title</h1>
                }
                @if (!string.IsNullOrEmpty(Subtitle))
                {
                    <div class="th-page-subtitle">@Subtitle</div>
                }
            </div>
            @if (Actions is not null)
            {
                <div class="th-page-actions">@Actions</div>
            }
        </div>
    }
    @ChildContent
</div>

@if (Footer is not null)
{
    <div class="@(FooterFixed ? "th-footer th-footer--fixed" : "th-footer")">@Footer</div>
}

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public bool Flush { get; set; }
    [Parameter] public bool FooterFixed { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
}

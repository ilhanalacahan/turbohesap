@namespace Turbohesap.Web.Components.Shell
@implements IDisposable
@inject Turbohesap.Web.Services.LayoutState Layout
@inject Turbohesap.Web.Services.AppNavigation Navigation
@inject Turbohesap.Web.Services.TabService Tabs
@inject NavigationManager Nav

@if (Layout.CommandOpen)
{
    <div class="th-command-overlay" @onclick="Layout.CloseCommand">
        <div class="th-command" @onclick:stopPropagation="true">
            <div class="th-command__search">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input class="th-command__input" placeholder="Sayfa ara veya komut çalıştır…"
                       value="@_search" @oninput="OnSearch" @onkeydown="OnKeyDown" autofocus />
            </div>
            <div class="th-command__results">
                @{
                    var results = Results().ToList();
                }
                @if (results.Count == 0)
                {
                    <div class="th-command__empty">Sonuç bulunamadı.</div>
                }
                else
                {
                    @foreach (var item in results)
                    {
                        <div class="th-command__item" @onclick="() => Go(item)">
                            <span class="th-command__item-icon"><i class="@item.Icon"></i></span>
                            <span>@item.Label</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    private string _search = string.Empty;

    protected override void OnInitialized() => Layout.OnChange += Changed;

    private IEnumerable<NavItem> Flatten(IEnumerable<NavItem> items)
    {
        foreach (var item in items)
        {
            if (item.Href is not null)
            {
                yield return item;
            }
            foreach (var child in Flatten(item.Children))
            {
                yield return child;
            }
        }
    }

    private IEnumerable<NavItem> Results()
    {
        var all = Navigation.Groups.SelectMany(g => Flatten(g.Items));
        return string.IsNullOrWhiteSpace(_search)
            ? all.Take(8)
            : all.Where(i => i.Label.Contains(_search, StringComparison.OrdinalIgnoreCase)).Take(12);
    }

    private void Go(NavItem item)
    {
        if (item.Href is null)
        {
            return;
        }
        Tabs.OpenOrFocus(new TabItem { Title = item.Label, Href = item.Href, Icon = item.Icon });
        Layout.CloseCommand();
        Nav.NavigateTo(item.Href);
    }

    private void OnSearch(ChangeEventArgs e) => _search = e.Value?.ToString() ?? string.Empty;

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            Layout.CloseCommand();
        }
        else if (e.Key == "Enter")
        {
            var first = Results().FirstOrDefault();
            if (first is not null)
            {
                Go(first);
            }
        }
    }

    private void Changed() => InvokeAsync(StateHasChanged);

    public void Dispose() => Layout.OnChange -= Changed;
}

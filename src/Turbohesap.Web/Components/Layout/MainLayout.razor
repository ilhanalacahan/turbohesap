@inherits LayoutComponentBase
@inject Turbohesap.Web.Services.LayoutState Layout
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@* Kod tarafı: MainLayout.razor.cs *@

@* Kabuk yalnızca kimliği doğrulanmış kullanıcıya gösterilir. Kontrol devre (circuit)
   içinde yapılır; sunucu uç noktası kimlik doğrulaması zorlamaz (token istemci tarafında). *@
@if (_ready)
{
    <div class="th-shell">
        <Sidebar />
        @if (Layout.SidebarOpen)
        {
            <div class="th-backdrop" @onclick="Layout.CloseSidebar"></div>
        }
        <div class="th-main">
            <AppBar />
            <PageTabs />
            <div class="th-content">
                <Turbohesap.Web.Components.Feedback.ThErrorBoundary @ref="_errorBoundary">
                    <ChildContent>
                        @Body
                    </ChildContent>
                    <ErrorContent>
                        <div class="th-page">
                            <div class="th-card" style="max-width:32rem;margin:2rem auto;text-align:center">
                                <div class="th-card__body" style="padding:2rem">
                                    <div style="font-size:2.25rem;color:var(--th-danger)"><i class="fa-solid fa-triangle-exclamation"></i></div>
                                    <h2 class="th-page-title" style="margin-top:0.5rem">Bir şeyler ters gitti</h2>
                                    <p style="color:var(--th-text-muted);margin:0.5rem 0 1.25rem">Bu sayfada beklenmeyen bir hata oluştu ve kayıt altına alındı.</p>
                                    <a href="." class="th-btn th-btn--primary"><i class="fa-solid fa-rotate-right"></i> Yeniden yükle</a>
                                </div>
                            </div>
                        </div>
                    </ErrorContent>
                </Turbohesap.Web.Components.Feedback.ThErrorBoundary>
            </div>
        </div>
    </div>

    <AppLauncher />
    <CommandLauncher />
    <ThemeDesigner />
    <AiChat />
    <ThToastHost />
    <ThModalHost />
    <ThDrawerHost />
}
else
{
    <div style="min-height:100dvh;display:flex;align-items:center;justify-content:center;color:var(--th-text-muted)">
        <i class="fa-solid fa-spinner fa-spin" style="font-size:1.5rem"></i>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    Beklenmeyen bir hata oluştu.
    <a href="." class="reload">Yenile</a>
    <span class="dismiss">🗙</span>
</div>


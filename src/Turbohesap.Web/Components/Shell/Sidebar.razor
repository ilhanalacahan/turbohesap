@namespace Turbohesap.Web.Components.Shell
@implements IDisposable
@inject Turbohesap.Web.Services.AppNavigation Navigation
@inject Turbohesap.Web.Services.LayoutState Layout
@inject NavigationManager Nav

<aside class="@SidebarClass">
    <div class="th-sidebar__header">
        <span class="th-sidebar__appicon" title="Uygulamalar" @onclick="Layout.ToggleAppLauncher">
            <i class="fa-solid fa-table-cells-large"></i>
        </span>
        <span class="th-sidebar__brand">Turbohesap</span>
    </div>

    <div class="th-sidebar__search">
        <input class="th-sidebar__search-input" type="search" placeholder="Menüde ara…"
               value="@_search" @oninput="OnSearch" />
    </div>

    <nav class="th-sidebar__nav">
        @foreach (var group in FilteredGroups())
        {
            <div class="th-nav-group">
                <div class="th-nav-group__label">@group.Title</div>
                @foreach (var item in group.Items)
                {
                    @RenderItem(item, true)
                }
            </div>
        }
    </nav>

    <div class="th-sidebar__footer">
        <span class="th-sidebar__footer-btn" @onclick="@(() => Go("/help"))">
            <i class="fa-solid fa-circle-question"></i><span>Yardım</span>
        </span>
        <span class="th-sidebar__footer-btn" @onclick="@(() => Go("/feedback"))">
            <i class="fa-solid fa-comment-dots"></i><span>Geri Bildirim</span>
        </span>
    </div>
</aside>

@code {
    // Görsel (recursive) öğe çizimi. İş mantığı Sidebar.razor.cs içindedir.
    private RenderFragment RenderItem(NavItem item, bool topLevel) => __builder =>
    {
        var isActive = item.Href is not null && IsActive(item.Href);
        var expanded = _expanded.Contains(item.Label);

        <div class="@(topLevel ? "th-nav-item-wrap" : null)">
            <div class="@(item.HasChildren && expanded ? "th-nav-item--expanded" : null)">
                <div class="@(isActive ? "th-nav-item th-nav-item--active" : "th-nav-item")"
                     @onclick="() => OnItemClick(item)">
                    <span class="th-nav-item__icon"><i class="@item.Icon"></i></span>
                    <span class="th-nav-item__label">@item.Label</span>
                    @if (item.HasChildren)
                    {
                        <i class="th-nav-item__chevron fa-solid fa-chevron-right"></i>
                    }
                </div>
                @if (item.HasChildren && expanded)
                {
                    <div class="th-nav-children">
                        @foreach (var child in item.Children)
                        {
                            @RenderItem(child, false)
                        }
                    </div>
                }
            </div>

            @* Daraltılmış sidebar'da ikon üzerine gelince açılan flyout (alt menü / etiket). *@
            @if (topLevel)
            {
                <div class="th-nav-flyout">
                    <div class="th-nav-flyout__title">@item.Label</div>
                    @if (item.HasChildren)
                    {
                        <div class="th-nav-flyout__list">
                            @foreach (var child in item.Children)
                            {
                                <div class="th-nav-flyout__item" @onclick="() => OnItemClick(child)">
                                    <span class="th-nav-item__icon"><i class="@child.Icon"></i></span>
                                    <span>@child.Label</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    };
}

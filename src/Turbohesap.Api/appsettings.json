{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=turbohesap;Username=postgres;Password=NETHESAP"
  },
  "Jwt": {
    "Issuer": "Turbohesap",
    "Audience": "TurbohesapClients",
    "SigningKey": "turbohesap-dev-signing-key-please-change-in-production-0123456789",
    "AccessTokenMinutes": 120
  },
  "Telemetry": {
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Wolverine": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/turbohesap-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "AllowedHosts": "*"
}
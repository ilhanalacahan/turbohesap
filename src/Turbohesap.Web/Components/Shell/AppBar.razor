@namespace Turbohesap.Web.Components.Shell
@inject Turbohesap.Web.Services.LayoutState Layout
@inject Turbohesap.Web.Services.ThemeInterop Theme
@inject Turbohesap.Web.Services.AuthClientService Auth
@inject NavigationManager Nav
@* Kod tarafı: AppBar.razor.cs *@

<header class="th-appbar">
    <div class="th-appbar__left">
        <span class="th-appbar__menu" title="Menü" @onclick="Layout.ToggleSidebar"><i class="fa-solid fa-bars"></i></span>
        <span class="th-appbar__collapse" title="Kenar çubuğunu daralt/genişlet" @onclick="Layout.ToggleCollapse"><i class="fa-solid fa-bars"></i></span>
        <nav class="th-breadcrumb">
            @for (var i = 0; i < _crumbs.Count; i++)
            {
                var isLast = i == _crumbs.Count - 1;
                <span class="@(isLast ? "th-breadcrumb__item th-breadcrumb__item--current" : "th-breadcrumb__item")">@_crumbs[i]</span>
                @if (!isLast)
                {
                    <i class="th-breadcrumb__sep fa-solid fa-chevron-right"></i>
                }
            }
        </nav>
    </div>

    <div class="th-appbar__center">
        <div class="th-appbar__search" @onclick="Layout.ToggleCommand">
            <i class="fa-solid fa-magnifying-glass"></i>
            <span>Ara veya komut çalıştır…</span>
            <kbd>Ctrl K</kbd>
        </div>
    </div>

    <div class="th-appbar__right">
        <span class="th-iconbtn" title="Tema tasarımcısı" @onclick="Layout.ToggleThemeDesigner">
            <i class="fa-solid fa-palette"></i>
        </span>
        <span class="th-iconbtn th-appbar__hide-mobile" title="Bildirimler">
            <i class="fa-solid fa-bell"></i>
            <span class="th-iconbtn__badge">3</span>
        </span>
        <span class="th-iconbtn" title="Gece/Gündüz" @onclick="ToggleDarkAsync">
            <i class="fa-solid fa-circle-half-stroke"></i>
        </span>

        <div style="position:relative">
            <span class="th-avatar" @onclick="ToggleUserMenu">@_initials</span>
            @if (_userMenuOpen)
            {
                <div class="th-card" style="position:absolute;right:0;top:2.75rem;width:14rem;z-index:var(--th-z-dropdown);box-shadow:var(--th-shadow-lg)">
                    <div class="th-card__body" style="padding:0.75rem">
                        <div style="font-weight:600;font-size:0.875rem">@_fullName</div>
                        <div style="font-size:0.75rem;color:var(--th-text-muted)">@_email</div>
                    </div>
                    <div class="th-card__footer" style="justify-content:stretch">
                        <button class="th-btn th-btn--ghost th-btn--block th-btn--sm" @onclick="LogoutAsync">
                            <i class="fa-solid fa-right-from-bracket"></i> Çıkış Yap
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</header>

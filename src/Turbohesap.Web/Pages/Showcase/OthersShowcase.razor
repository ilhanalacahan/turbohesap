@namespace Turbohesap.Web.Pages.Showcase
@using Turbohesap.Web.Components.Tooltip
@using Turbohesap.Web.Components.Popover
@using Turbohesap.Web.Components.Alert
@using Turbohesap.Web.Components.Breadcrumb
@using Turbohesap.Web.Components.Spinner
@using Turbohesap.Web.Components.Badge
@using Turbohesap.Web.Components.Feedback
@using Turbohesap.Web.Components.Input

<ThCard Title="Yeni Yardımcı Bileşenler" Subtitle="Tooltip, Popover, Alert, Breadcrumb ve Spinner bileşenleri" Icon="fa-solid fa-layer-group">
    <div class="flex flex-col gap-4">
        
        <!-- Breadcrumb (Ekmek Kırıntısı) Bölümü -->
        <div>
            <h4 class="text-sm font-semibold mb-2">Yol Patikası (Breadcrumb)</h4>
            <ThBreadcrumb Items="_breadcrumbItems" />
        </div>

        <hr class="border-border my-1" />

        <!-- Alert (Uyarı Kutuları) Bölümü -->
        <div>
            <h4 class="text-sm font-semibold mb-2">Uyarı Kutuları (Alerts)</h4>
            <div class="flex flex-col gap-2 py-1">
                <ThAlert Variant="AlertVariant.Success" Title="Başarılı İşlem" Closable="true" OnClose="OnAlertClosed">
                    Veriler başarıyla eşitlendi ve kaydedildi.
                </ThAlert>
                <ThAlert Variant="AlertVariant.Danger" Title="Sistem Hatası" Closable="true">
                    Sunucu bağlantısı kurulamadı. Lütfen tekrar deneyin.
                </ThAlert>
            </div>
        </div>

        <hr class="border-border my-1" />

        <!-- Tooltip & Popover Bölümü -->
        <div>
            <h4 class="text-sm font-semibold mb-2">İpuçları & Balonlar (Tooltip & Popover)</h4>
            <div class="flex flex-wrap gap-3 items-center py-1">
                <ThTooltip Text="Üst İpucu (Top)" Position="TooltipPosition.Top">
                    <ThButton Variant="ButtonVariant.Outline" Size="ComponentSize.Sm">Tooltip (Hover)</ThButton>
                </ThTooltip>
                
                <ThPopover Title="Popover Seçenekleri" Position="PopoverPosition.Bottom" ShowCloseButton="true">
                    <Trigger>
                        <ThButton Variant="ButtonVariant.Primary" Size="ComponentSize.Sm" Icon="fa-solid fa-sliders">Popover (Tıkla)</ThButton>
                    </Trigger>
                    <ChildContent>
                        <div class="flex flex-col gap-2 min-w-[180px] p-1">
                            <span class="text-xs font-semibold text-text-muted">GÖSTERİM AYARLARI</span>
                            <ThCheckbox @bind-Value="_showGrid" Label="Izgarayı Göster" />
                            <ThCheckbox @bind-Value="_enableLogs" Label="Logları Etkinleştir" />
                        </div>
                    </ChildContent>
                </ThPopover>
            </div>
        </div>

        <hr class="border-border my-1" />

        <!-- Spinner (Döndürücü) Bölümü -->
        <div>
            <h4 class="text-sm font-semibold mb-2">Yükleniyor Göstergeleri (Spinners)</h4>
            <div class="flex flex-wrap gap-4 items-center py-1">
                <ThSpinner Size="ComponentSize.Sm" Variant="SpinnerVariant.Primary" />
                <ThSpinner Size="ComponentSize.Md" Variant="SpinnerVariant.Success" />
                <ThSpinner Size="ComponentSize.Lg" Variant="SpinnerVariant.Danger" />
            </div>
        </div>

        <hr class="border-border my-1" />

        <!-- Akıllı Durum ve Trend Rozetleri -->
        <div>
            <h4 class="text-sm font-semibold mb-2">Akıllı Durum ve Trend Rozetleri</h4>
            <div class="flex flex-col gap-4 py-1">
                <div class="flex flex-wrap gap-1.5">
                    <ThStatusBadge Status="Draft" Label="Taslak" />
                    <ThStatusBadge Status="Processing" Label="İşleniyor" />
                    <ThStatusBadge Status="Completed" Label="Tamamlandı" />
                    <ThStatusBadge Status="Cancelled" Label="İptal Edildi" />
                </div>
                <div class="flex flex-wrap gap-2 pt-2 border-t border-border/60">
                    <ThTrending Value="0.124" Format="p1" Size="ComponentSize.Sm" />
                    <ThTrending Value="-0.032" Format="p1" Size="ComponentSize.Sm" />
                    <ThTrending Value="2450" Format="c0" ShowSign="true" Size="ComponentSize.Sm" />
                </div>
            </div>
        </div>

        <hr class="border-border my-1" />

        <!-- Klavye Kısayol İpuçları -->
        <div>
            <h4 class="text-sm font-semibold mb-2">Klavye Kısayol İpuçları</h4>
            <div class="flex flex-col gap-3 py-1">
                <div class="flex items-center justify-between text-xs">
                    <span class="text-text-muted">Arama Yap:</span>
                    <ThShortcutHint Keys="Ctrl+K" />
                </div>
                <div class="flex items-center justify-between text-xs">
                    <span class="text-text-muted">Satırı Kaydet:</span>
                    <ThShortcutHint Keys="Ctrl+Enter" />
                </div>
                <div class="flex items-center justify-between text-xs">
                    <span class="text-text-muted">Geri Dön:</span>
                    <ThShortcutHint Keys="Esc" />
                </div>
            </div>
        </div>

        <hr class="border-border my-1" />

        <!-- Boş Veri Şablonları -->
        <div>
            <h4 class="text-sm font-semibold mb-2">Boş Veri Şablonları (Empty States)</h4>
            <div class="flex flex-col gap-4 py-1">
                <div class="border border-border rounded-lg p-3 bg-surface">
                    <ThEmptyState Title="Henüz Fatura Eklenmedi" 
                                  Description="Sisteme kayıtlı fatura bulunamadı."
                                  Icon="fa-solid fa-file-invoice-dollar"
                                  Size="ComponentSize.Sm"
                                  ActionButtonText="Oluştur"
                                  OnActionClick="OnEmptyStateActionClick" />
                </div>
                <div class="border border-border rounded-lg p-3 bg-surface">
                    <ThEmptyState Title="Sonuç Bulunamadı" 
                                  Description="Kriterlere uygun kayıt yok."
                                  Icon="fa-solid fa-magnifying-glass"
                                  Size="ComponentSize.Sm" />
                </div>
            </div>
        </div>

    </div>
</ThCard>

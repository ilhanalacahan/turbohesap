@namespace Turbohesap.Web.Pages.Showcase
@using Turbohesap.Web.Components.Card
@using Turbohesap.Web.Components.Badge
@using Turbohesap.Web.Components.Progress
@using Turbohesap.Web.Components.Data
@using Turbohesap.Web.Components.Input

<ThCard Title="Gelişmiş Görsel & Analitik Bileşenler" Subtitle="Kpi, Heatmap Yoğunluk Matrisi, İş Akış Şeridi, Dönüşüm Hunisi ve Mini Segment Barları" Icon="fa-solid fa-chart-line">
    <div class="flex flex-col gap-8">
        
        <!-- KPI Metrik Kartları (ThKpiCard) -->
        <div>
            <h4 class="text-sm font-semibold mb-3">KPI Metrik Kartları (ThKpiCard - Sparkline Çizgili)</h4>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 py-1">
                <ThKpiCard Title="Aylık Satış Cirosu" 
                           Value="45.230,00 ₺" 
                           TrendValue="@(0.124M)" 
                           TrendLabel="geçen haftaya göre"
                           Icon="fa-solid fa-money-bill-trend-up"
                           SparklineData="_kpiSalesData" />

                <ThKpiCard Title="Aylık Harcamalar" 
                           Value="13.800,00 ₺" 
                           TrendValue="@(-0.032M)" 
                           TrendLabel="geçen haftaya göre"
                           Icon="fa-solid fa-wallet"
                           SparklineData="_kpiExpensesData" />

                <ThKpiCard Title="Depo Stok Hacmi" 
                           Value="158 Palet" 
                           TrendValue="@(0.185M)" 
                           TrendLabel="son 7 günde"
                           Icon="fa-solid fa-boxes-stacked"
                           SparklineData="_kpiStockData" />
            </div>
        </div>

        <hr class="border-border my-1" />

        <!-- Aktivite Yoğunluk Matrisi (ThHeatmapCalendar) -->
        <div>
            <h4 class="text-sm font-semibold mb-3">Aktivite Yoğunluk Matrisi (ThHeatmapCalendar - Son 3 Ay)</h4>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 py-1 items-start">
                <div class="lg:col-span-2">
                    <ThHeatmapCalendar Title="Depo Mal Kabul / Çıkış İşlemleri"
                                       ActivityData="_heatmapActivities"
                                       MaxActivityValue="10"
                                       ColorVariant="_heatmapColor"
                                       MonthCount="3" />
                </div>
                <div class="border border-border rounded p-4 bg-surface-2 flex flex-col gap-3 text-xs">
                    <h5 class="text-xs font-semibold text-text uppercase tracking-wider">Yoğunluk Kontrol Paneli</h5>
                    <p class="text-text-muted leading-relaxed">Aktivite yoğunluğunu ve renk varyantını canlı olarak test edebilirsiniz:</p>
                    
                    <div class="flex flex-col gap-1.5 mt-1">
                        <span class="text-text-subtle font-medium">Renk Teması:</span>
                        <div class="flex flex-wrap gap-1.5">
                            <ThButton Variant="ButtonVariant.Primary" Size="ComponentSize.Sm" OnClick="() => ChangeHeatmapColor(HeatmapColor.Primary)">Primary</ThButton>
                            <ThButton Variant="ButtonVariant.Success" Size="ComponentSize.Sm" OnClick="() => ChangeHeatmapColor(HeatmapColor.Success)">Success</ThButton>
                            <ThButton Variant="ButtonVariant.Subtle" Size="ComponentSize.Sm" OnClick="() => ChangeHeatmapColor(HeatmapColor.Warning)">Warning</ThButton>
                            <ThButton Variant="ButtonVariant.Danger" Size="ComponentSize.Sm" OnClick="() => ChangeHeatmapColor(HeatmapColor.Danger)">Danger</ThButton>
                        </div>
                    </div>

                    <div class="flex gap-2 mt-2 pt-2 border-t border-border">
                        <ThButton Variant="ButtonVariant.Outline" Size="ComponentSize.Sm" OnClick="GenerateRandomHeatmapData" Class="flex-1">
                            <i class="fa-solid fa-rotate mr-1"></i> Veri Üret
                        </ThButton>
                        <ThButton Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm" OnClick="ClearHeatmapData" Class="text-danger hover:bg-danger-subtle flex-1">
                            <i class="fa-solid fa-trash mr-1"></i> Temizle
                        </ThButton>
                    </div>
                </div>
            </div>
        </div>

        <hr class="border-border my-1" />

        <!-- Süreç İş Akış Şeridi (ThProcessFlow) -->
        <div>
            <h4 class="text-sm font-semibold mb-3">Süreç İş Akış Şeridi (ThProcessFlow - Yatay ve Dikey)</h4>
            <div class="flex flex-col gap-6 py-1">
                <!-- Yatay Akış Simülatörlü -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
                    <div class="lg:col-span-2 border border-border rounded p-4 bg-surface flex flex-col gap-3 min-h-[140px] justify-center">
                        <h5 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-2">Yatay Akış Düzeni</h5>
                        <ThProcessFlow Steps="_processFlowSteps" Vertical="false" OnStepClick="HandleStepClick" />
                    </div>
                    <div class="border border-border rounded p-4 bg-surface-2 flex flex-col gap-3 text-xs">
                        <h5 class="text-xs font-semibold text-text uppercase tracking-wider">İş Akışı Durum Simülatörü</h5>
                        <p class="text-text-muted leading-relaxed">Akış adımlarının durumunu simüle edin (Akış çizgileri otomatik renk değiştirir):</p>
                        
                        <div class="flex flex-col gap-2 mt-2">
                            <ThButton Variant="ButtonVariant.Success" Size="ComponentSize.Sm" OnClick="CompleteStep3">
                                3. Adımı Tamamla (4. Adımı Aktif Yap)
                            </ThButton>
                            <ThButton Variant="ButtonVariant.Danger" Size="ComponentSize.Sm" OnClick="FailStep3">
                                3. Adımı Başarısız Yap
                            </ThButton>
                            <ThButton Variant="ButtonVariant.Outline" Size="ComponentSize.Sm" OnClick="ResetSteps">
                                Süreci Başlangıca Sıfırla
                            </ThButton>
                        </div>
                    </div>
                </div>

                <!-- Dikey Akış -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
                    <div class="lg:col-span-2 border border-border rounded p-4 bg-surface flex flex-col gap-3">
                        <h5 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-2">Dikey Akış Düzeni</h5>
                        <ThProcessFlow Steps="_processFlowSteps" Vertical="true" OnStepClick="HandleStepClick" />
                    </div>
                    <div class="bg-surface-2 border border-border rounded p-4 text-xs leading-relaxed text-text-subtle">
                        <h5 class="text-xs font-semibold text-text uppercase tracking-wider mb-1">Dikey Akış Özellikleri</h5>
                        <p class="mb-2">Dikey yerleşim özellikle sol menüler, sipariş geçmişi ve detay sayfalarında kronolojik log takibi için kullanılır.</p>
                        <p>Klavye odağı alanları ve hover efektleri ile interaktif tıklanabilir adımlar mevcuttur.</p>
                    </div>
                </div>
            </div>
        </div>

        <hr class="border-border my-1" />

        <!-- Dönüşüm Hunisi & Mikro Segmentli İlerleme Çubuğu -->
        <div>
            <h4 class="text-sm font-semibold mb-3">Dönüşüm Hunisi & Mikro Segment Dağılım Çubuğu</h4>
            <div class="flex flex-col gap-6 py-1">
                <!-- Funnel Chart Simülatörlü -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
                    <div class="lg:col-span-2 border border-border rounded p-4 bg-surface flex flex-col gap-3">
                        <h5 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-2">Dönüşüm Hunisi Grafiği (ThFunnelChart)</h5>
                        <ThFunnelChart Title="Teklif - Sipariş Dönüşümü" Stages="_funnelStages" />
                    </div>
                    <div class="border border-border rounded p-4 bg-surface-2 flex flex-col gap-3 text-xs">
                        <h5 class="text-xs font-semibold text-text uppercase tracking-wider">Huni Aşama Değerlerini Ayarla</h5>
                        <p class="text-text-muted leading-relaxed">Huni dilimlerinin genişliklerini dinamik olarak test edin:</p>
                        
                        <div class="flex flex-col gap-3 mt-2">
                            @for (int i = 0; i < _funnelStages.Count; i++)
                            {
                                var index = i;
                                var stage = _funnelStages[i];
                                <div class="flex flex-col gap-1">
                                    <div class="flex justify-between font-medium">
                                        <span>@stage.Label</span>
                                        <span class="font-mono text-primary">@stage.Value</span>
                                    </div>
                                    <input type="range" min="10" max="200" step="5"
                                           value="@stage.Value"
                                           @oninput="@((ChangeEventArgs e) => UpdateFunnelStageValue(index, Convert.ToDouble(e.Value)))"
                                           class="w-full h-1 bg-border rounded-lg appearance-none cursor-pointer accent-primary" />
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Mini Progress Bar Simülatörlü -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
                    <div class="lg:col-span-2 border border-border rounded p-4 bg-surface flex flex-col gap-4">
                        <h5 class="text-xs font-semibold text-text-muted uppercase tracking-wider">Stok Kategori Dağılımı (ThMiniProgressBar)</h5>
                        <div class="flex flex-col gap-5">
                            <div class="flex flex-col gap-1.5">
                                <span class="text-xs text-text-muted">Mevcut Envanter Tipi Oranları (Md):</span>
                                <ThMiniProgressBar Segments="_miniProgressSegments" Size="ComponentSize.Md" ShowLegend="true" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <span class="text-xs text-text-muted">Kompakt Liste Gösterimi (Sm - Göstergesiz):</span>
                                <ThMiniProgressBar Segments="_miniProgressSegments" Size="ComponentSize.Sm" ShowLegend="false" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <span class="text-xs text-text-muted">Kalın Gösterim (Lg):</span>
                                <ThMiniProgressBar Segments="_miniProgressSegments" Size="ComponentSize.Lg" ShowLegend="true" />
                            </div>
                        </div>
                    </div>
                    <div class="border border-border rounded p-4 bg-surface-2 flex flex-col gap-3 text-xs">
                        <h5 class="text-xs font-semibold text-text uppercase tracking-wider">Segment Dağılım Ayarları</h5>
                        <p class="text-text-muted leading-relaxed">Dağılım dilimlerinin oranlarını değiştirerek bar genişliklerini simüle edin:</p>
                        
                        <div class="flex flex-col gap-3 mt-2">
                            @for (int i = 0; i < _miniProgressSegments.Count; i++)
                            {
                                var index = i;
                                var segment = _miniProgressSegments[i];
                                <div class="flex flex-col gap-1">
                                    <div class="flex justify-between font-medium">
                                        <span>@segment.Label</span>
                                        <span class="font-mono text-primary">@segment.Value</span>
                                    </div>
                                    <input type="range" min="0" max="600" step="10"
                                           value="@segment.Value"
                                           @oninput="@((ChangeEventArgs e) => UpdateSegmentValue(index, Convert.ToDouble(e.Value)))"
                                           class="w-full h-1 bg-border rounded-lg appearance-none cursor-pointer accent-primary" />
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <hr class="border-border my-1" />

        <!-- Müşteri Derecelendirme (ThCustomerRating) -->
        <div>
            <h4 class="text-sm font-semibold mb-3">Müşteri Derecelendirme Göstergesi (ThCustomerRating)</h4>
            <p class="text-xs text-text-muted mb-4 leading-relaxed max-w-3xl">
                Ödeme zamanlaması, alışveriş hacmi ve sıklığı gibi kriterleri <strong>ağırlıklı</strong> bir genel puana indirger;
                puanı radyal madalyon, harf notu (A–D), yıldız ve kademe renkleriyle (Mükemmel / İyi / Orta / Riskli) görselleştirir.
            </p>

            <!-- Örnek Müşteri Kartları -->
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 py-1 items-start">
                <ThCustomerRating CustomerName="Mega Yapı Market A.Ş."
                                  Subtitle="CARİ-1042 · Bayi"
                                  Factors="_excellentCustomerFactors" />

                <ThCustomerRating CustomerName="Yıldız Ticaret Ltd."
                                  Subtitle="CARİ-2208 · Perakende"
                                  Factors="_goodCustomerFactors" />

                <ThCustomerRating CustomerName="Deneme İnşaat"
                                  Subtitle="CARİ-3391 · Proje"
                                  Factors="_riskyCustomerFactors" />
            </div>

            <!-- Canlı Derecelendirme Simülatörü -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start mt-6">
                <div class="lg:col-span-2 border border-border rounded p-4 bg-surface flex flex-col justify-center">
                    <h5 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-4">Canlı Derecelendirme (Kriterlere göre yeniden hesaplanır)</h5>
                    <ThCustomerRating CustomerName="Test Cari Hesabı"
                                      Subtitle="Kriterleri sağdan ayarlayın"
                                      Factors="_ratingSimFactors"
                                      Size="ComponentSize.Lg" />
                </div>
                <div class="border border-border rounded p-4 bg-surface-2 flex flex-col gap-3 text-xs">
                    <h5 class="text-xs font-semibold text-text uppercase tracking-wider">Kriter Puanlarını Ayarla</h5>
                    <p class="text-text-muted leading-relaxed">Her kriterin iyilik puanını (0–100) değiştirin; genel not ve kademe anında güncellenir:</p>

                    <div class="flex flex-col gap-3 mt-2">
                        @for (int i = 0; i < _ratingSimFactors.Count; i++)
                        {
                            var index = i;
                            var factor = _ratingSimFactors[i];
                            <div class="flex flex-col gap-1">
                                <div class="flex justify-between font-medium">
                                    <span><i class="@factor.Icon mr-1.5 text-text-subtle"></i>@factor.Label</span>
                                    <span class="font-mono text-primary">@Math.Round(factor.Value)</span>
                                </div>
                                <input type="range" min="0" max="100" step="1"
                                       value="@factor.Value"
                                       @oninput="@((ChangeEventArgs e) => UpdateRatingFactor(index, Convert.ToDouble(e.Value)))"
                                       class="w-full h-1 bg-border rounded-lg appearance-none cursor-pointer accent-primary" />
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</ThCard>

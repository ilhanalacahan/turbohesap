@page "/error"
@layout Turbohesap.Web.Components.Layout.AuthLayout

<div class="th-auth-center">
<div class="th-card" style="width:100%;max-width:26rem;text-align:center">
    <div class="th-card__body" style="padding:2rem">
        <div style="font-size:2.5rem;color:var(--th-danger)"><i class="fa-solid fa-triangle-exclamation"></i></div>
        <h1 class="th-page-title" style="margin-top:0.5rem">Bir hata oluştu</h1>
        <p style="color:var(--th-text-muted);margin:0.5rem 0 1rem">İşleminiz sırasında beklenmeyen bir hata meydana geldi.</p>
        @if (ShowRequestId)
        {
            <p style="font-size:0.75rem;color:var(--th-text-subtle)">İstek No: <code>@RequestId</code></p>
        }
        <a href="/" class="th-btn th-btn--primary"><i class="fa-solid fa-house"></i> Ana sayfa</a>
    </div>
</div>
</div>

@namespace Turbohesap.Web.Components.Input
@inherits Turbohesap.Web.Components.Base.TurboComponentBase
@typeparam TValue
@using System.Linq.Expressions
@using Microsoft.AspNetCore.Components.Forms

@* Form alanı sarmalayıcısı: etiket + içerik (InputText vb.) + FluentValidation mesajı.
   Doğrulama mesajı For ifadesinden gelir; EditForm içinde kullanılır (req 5, 14). *@
<div class="@Cx("th-field", Class)">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="@(Required ? "th-label th-label--required" : "th-label")">@Label</label>
    }
    @ChildContent
    @if (For is not null)
    {
        <ValidationMessage For="For" class="th-error" />
    }
    @if (!string.IsNullOrEmpty(Hint))
    {
        <span class="th-hint">@Hint</span>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Hint { get; set; }
    [Parameter] public bool Required { get; set; }

    /// <summary>Doğrulama mesajının bağlanacağı alan ifadesi, örn. <c>() => model.Email</c>.</summary>
    [Parameter] public Expression<Func<TValue>>? For { get; set; }
}

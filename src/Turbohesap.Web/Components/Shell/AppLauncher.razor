@namespace Turbohesap.Web.Components.Shell
@implements IDisposable
@inject Turbohesap.Web.Services.LayoutState Layout
@inject Turbohesap.Web.Services.AppNavigation Navigation
@inject NavigationManager Nav

@* Uygulama başlatıcı — ortalanmış, ferah ızgara (Microsoft 365 tarzı). *@
@if (Layout.AppLauncherOpen)
{
    <div class="th-applauncher-overlay" @onclick="Layout.CloseAppLauncher">
        <div class="th-applauncher" @onclick:stopPropagation="true">
            <div class="th-applauncher__head">
                <div>
                    <div class="th-applauncher__title">Uygulamalar</div>
                    <div class="th-applauncher__subtitle">Bir modüle geçmek için seçin</div>
                </div>
                <span class="th-dialog__close" title="Kapat" @onclick="Layout.CloseAppLauncher"><i class="fa-solid fa-xmark"></i></span>
            </div>
            <div class="th-applauncher__grid">
                @foreach (var app in Navigation.Apps)
                {
                    <button type="button" class="th-app-tile" @onclick="() => Open(app)">
                        <span class="th-app-tile__icon" style="--accent:@app.Accent"><i class="@app.Icon"></i></span>
                        <span class="th-app-tile__name">@app.Name</span>
                        @if (app.Description is not null)
                        {
                            <span class="th-app-tile__desc">@app.Description</span>
                        }
                        @if (app.ComingSoon)
                        {
                            <span class="th-app-tile__soon">Yakında</span>
                        }
                    </button>
                }
            </div>
        </div>
    </div>
}

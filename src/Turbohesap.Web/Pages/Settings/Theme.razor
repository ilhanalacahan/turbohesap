@page "/settings/theme"
@inject Turbohesap.Web.Services.LayoutState Layout
<PageTitle>Tema Tasarımcısı · Turbohesap</PageTitle>

@* Tema özelleştirme artık sağdan açılan tasarımcı drawer'ı üzerinden yapılır (tek kaynak).
   Bu sayfa yalnızca o paneli açar. *@
<ThPage Title="Tema Tasarımcısı" Subtitle="Görünümü gerçek zamanlı özelleştirin" TabIcon="fa-solid fa-palette">
    <div class="th-card" style="max-width:34rem">
        <div class="th-card__body flex flex-col gap-4">
            <p class="text-text-muted text-sm">
                Görünüm modu, ana renk, yazı tipi, yerleşim yoğunluğu, köşe yuvarlaklığı ve arayüz
                ölçeğini sağdan açılan <strong>Tema Tasarımcısı</strong> panelinden ayarlayabilirsiniz.
                Değişiklikler anında uygulanır ve cihazınızda saklanır.
            </p>
            <div>
                <ThButton Variant="ButtonVariant.Primary" Icon="fa-solid fa-palette" OnClick="Layout.ToggleThemeDesigner">
                    Tema Tasarımcısını Aç
                </ThButton>
            </div>
        </div>
    </div>
</ThPage>

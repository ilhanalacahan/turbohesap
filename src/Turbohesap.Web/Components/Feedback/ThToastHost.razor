@namespace Turbohesap.Web.Components.Feedback
@inject Turbohesap.Web.Services.ToastService Toasts

<div class="th-toast-region" aria-live="polite">
    @foreach (var toast in Toasts.Toasts)
    {
        <div class="@($"th-toast {toast.CssClass}")" @key="toast.Id">
            <i class="@($"th-toast__icon {toast.IconClass}")"></i>
            <div class="th-toast__content">
                @if (!string.IsNullOrEmpty(toast.Title))
                {
                    <div class="th-toast__title">@toast.Title</div>
                }
                <div class="th-toast__message">@toast.Message</div>
            </div>
            <i class="th-toast__close fa-solid fa-xmark" @onclick="() => Toasts.Remove(toast.Id)"></i>
        </div>
    }
</div>
